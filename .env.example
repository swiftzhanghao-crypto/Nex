# ==========================
# 前端配置（VITE_ 前缀的会被打包进浏览器，不可放任何密钥）
# ==========================

# 后端 API 模式（设为 true 启用后端，默认 false 使用 mock 数据）
VITE_API_MODE=false

# API 地址（默认 http://localhost:3001/api）
VITE_API_URL=http://localhost:3001/api

# ==========================
# 后端配置（仅在服务端读取，浏览器不可见）
# ==========================

# JWT 密钥（生产环境必须设置为强随机字符串，开发模式下若缺失会自动生成临时密钥并警告）
JWT_SECRET=wps365-dev-secret-change-in-production

# JWT 有效期（默认 24h，建议生产环境配合 refresh-token 使用更短时间）
JWT_EXPIRES_IN=24h

# Gemini AI Key（可选；服务端读取，由 /api/ai/* 代理转发；不要使用 VITE_ 前缀）
GEMINI_API_KEY=

# 允许的跨域来源（逗号分隔，默认 http://localhost:5173 等开发地址）
# CORS_ORIGINS=https://your-domain.com
