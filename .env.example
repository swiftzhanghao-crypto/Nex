# ==========================
# 前端配置（VITE_ 前缀的会被打包进浏览器，不可放任何密钥）
# ==========================

# 后端 API 模式（设为 true 启用后端，默认 false 使用 mock 数据）
VITE_API_MODE=false

# API 地址（默认 http://localhost:3001/api）
VITE_API_URL=http://localhost:3001/api

# ==========================
# 后端配置（仅在服务端读取，浏览器不可见）
# ==========================

# JWT 密钥（生产环境必须设置为强随机字符串，开发模式下若缺失会自动生成临时密钥并警告）
JWT_SECRET=wps365-dev-secret-change-in-production

# JWT 有效期（默认 24h，建议生产环境配合 refresh-token 使用更短时间）
JWT_EXPIRES_IN=24h

# Gemini AI Key（可选；服务端读取，由 /api/ai/* 代理转发；不要使用 VITE_ 前缀）
GEMINI_API_KEY=

# 允许的跨域来源（逗号分隔，默认 http://localhost:5173 等开发地址）
# CORS_ORIGINS=https://your-domain.com

# ---------- WPS 365 企业自建应用 OAuth2（Cookie+sid 方案，可选）----------
# 三项均配置后登录页显示「WPS 365 账号登录」；回调地址须与 WPS 开发者后台完全一致
# WPS_APP_ID=
# WPS_APP_SECRET=
# WPS_REDIRECT_URI=http://localhost:3001/api/auth/wps/callback
# OAuth 网关（一般不改）
# WPS_OPENAPI_BASE=https://openapi.wps.cn
# 逗号分隔 scope（WPS 非标准 OAuth2，用逗号不用空格），默认 kso.user_base.read
# WPS_SCOPES=kso.user_base.read
# SSO 完成后回跳的前端根地址（开发默认 http://localhost:5173；生产填实际域名）
# WPS_SSO_FRONTEND_URL=http://localhost:5173

# SSO Session Cookie 配置
# COOKIE_NAME=itab-sid
# COOKIE_SECURE=false
# COOKIE_SAMESITE=Lax

# ---------- 销售易 CRM OAuth2（可选；配置后客户管理页显示「CRM 授权」入口）----------
# 三项都配置后启用；redirect_uri 须与销售易开放平台白名单完全一致
# CRM_XSY_CLIENT_ID=
# CRM_XSY_CLIENT_SECRET=
# CRM_XSY_REDIRECT_URI=http://localhost:3001/api/crm/xsy/callback
# OAuth 基址（sandbox / 正式环境不同）
# CRM_XSY_OAUTH_BASE=https://login-sandbox.xiaoshouyi.com
# 数据 API 基址
# CRM_XSY_API_BASE=https://api-sandbox.xiaoshouyi.com
# 权限范围（默认 all）
# CRM_XSY_SCOPE=all
